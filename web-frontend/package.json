{
    "name": "web-frontend",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "es:fix": "eslint --cache --fix .",
        "fix": "pnpm fmt:fix && pnpm es:fix",
        "fmt": "prettier --experimental-cli --cache-location .prettiercache --check .",
        "fmt:fix": "prettier --experimental-cli --cache-location .prettiercache --write .",
        "lint": "pnpm --workspace-root --parallel /^lint:/",
        "lint:es": "eslint --cache .",
        "lint:sv": "svelte-check --tsconfig ./tsconfig.json"
    },
    "devDependencies": {
        "@bastidood/eslint-plugin-imsort": "^0.12.0",
        "@eslint/compat": "^2.1.0",
        "@eslint/css": "^1.2.0",
        "@eslint/js": "^10.0.1",
        "@html-eslint/eslint-plugin": "^0.60.0",
        "@html-eslint/eslint-plugin-svelte": "^0.60.0",
        "@sveltejs/adapter-node": "^5.5.4",
        "@sveltejs/kit": "^2.61.0",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/forms": "^0.5.11",
        "@tailwindcss/vite": "^4.3.0",
        "@types/node": "^25.9.1",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.17.1",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "prettier-plugin-svelte": "^4.0.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "svelte": "^5.55.9",
        "svelte-check": "^4.4.8",
        "svelte-eslint-parser": "^1.6.1",
        "tailwind-csstree": "^0.3.2",
        "tailwindcss": "^4.3.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.4",
        "vite": "^8.0.14"
    },
    "dependencies": {
        "@tiptap/core": "^3.23.6",
        "@tiptap/pm": "^3.23.6",
        "@tiptap/starter-kit": "^3.23.6"
    }
}
